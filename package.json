{
  "name": "billion-live-electron",
  "version": "0.0.1",
  "description": "Billion Live Electron",
  "main": "main.js",
  "author": "Billion Live",
  "license": "MIT",
  "scripts": {
    "serve": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "lint": "vue-cli-service lint",
    "prestart": "node ./scripts/prestart.js",
    "start": "concurrently \"npm run serve\" \"npm run electron\"",
    "preelectron": "node scripts/postinstall.js",
    "electron": "electron .",
    "build:win64": "electron-builder --win --x64",
    "pack:win64": "npm run build && npm run build:win64",
    "pack:mac-x64": "rm -rf release && npm run build && electron-builder --mac --x64"
  },
  "dependencies": {
    "@tencentcloud/tuiroom-engine-electron": "3.6.0-beta.1",
    "@tencentcloud/uikit-base-component-vue3": "1.3.5",
    "tuikit-atomicx-vue3-electron": "0.0.2",
    "core-js": "^3.36.1",
    "movable-resizable-js": "^0.2.0",
    "pinia": "^2.1.7",
    "trtc-electron-plugin-xmagic": "^0.0.20",
    "trtc-electron-sdk": "13.0.709-beta.1",
    "vue": "^3.4.0",
    "vue-router": "^4.3.1"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vue/cli-plugin-babel": "~5.0.8",
    "@vue/cli-plugin-eslint": "~5.0.8",
    "@vue/cli-plugin-router": "~5.0.8",
    "@vue/cli-plugin-typescript": "~5.0.8",
    "@vue/cli-plugin-vuex": "~5.0.8",
    "@vue/cli-service": "~5.0.8",
    "@vue/eslint-config-typescript": "^9.1.0",
    "axios": "^1.6.8",
    "concurrently": "^8.2.2",
    "electron": "^19.1.9",
    "electron-builder": "23.6.0",
    "electron-devtools-installer": "^3.2.0",
    "eslint": "^7.32.0",
    "eslint-plugin-vue": "^8.7.1",
    "extract-zip": "^2.0.1",
    "jose": "^1.28.2",
    "native-ext-loader": "^2.3.0",
    "replace": "^1.2.1",
    "request": "^2.88.2",
    "sass": "^1.72.0",
    "sass-loader": "^12.6.0"
  },
  "overrides": {
    "@tencentcloud/tuiroom-engine-electron": {
      "trtc-electron-sdk": "$trtc-electron-sdk"
    }
  }
}